# =============================================================================
# Financial Document Management — environment template
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# NEVER commit `.env`.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME="Financial Document Management"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Must be >=32 characters. The example value below is rejected at startup.
JWT_SECRET_KEY=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=fin-doc-mgmt
JWT_AUDIENCE=fin-doc-mgmt-clients

# -----------------------------------------------------------------------------
# Bootstrap admin (auto-created on first start if no users exist)
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=admin
# Must be >=12 chars. Used only when the users table is empty.
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!Now-2026

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite by default (file lives under ./data/). For Postgres use:
#   postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/app.db

# -----------------------------------------------------------------------------
# File storage (uploaded documents)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=20971520   # 20 MiB
ALLOWED_UPLOAD_MIMES=application/pdf,text/plain,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# -----------------------------------------------------------------------------
# Qdrant vector store
# -----------------------------------------------------------------------------
# Local dev: `docker compose up qdrant` will expose this URL.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=financial_documents

# -----------------------------------------------------------------------------
# Embedding / rerank provider
# -----------------------------------------------------------------------------
# Two providers are supported. The collection is auto-recreated if you switch
# providers and the vector dimension changes — safe for dev, destructive for
# any indexed corpus, so use distinct QDRANT_COLLECTION names per provider in
# production.
#
#   local_bge      — sentence-transformers BGE running in-process.
#                    Requires huggingface.co to be reachable on first run so
#                    the model weights (~140 MiB total) can be downloaded and
#                    cached locally.
#   cisco_aiverse  — Cisco's internal AIverse gateway over OAuth2 client
#                    credentials. No model download required, but the OAuth
#                    client must have FMSConsumer access provisioned for
#                    embeddinggemma-300m and granite-reranker via the CPP
#                    Console.
EMBEDDING_PROVIDER=local_bge

# -----------------------------------------------------------------------------
# Models — local_bge provider
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
# Must match the embedding model's output dimension:
#   bge-small-en-v1.5            -> 384
#   embeddinggemma-300m (Cisco)  -> 768
EMBEDDING_DIM=384

# -----------------------------------------------------------------------------
# Cisco AIverse — only used when EMBEDDING_PROVIDER=cisco_aiverse
# -----------------------------------------------------------------------------
# Get credentials from your Duo SSO OAuth2 client.
# Token URL pattern: https://sso-dbbfec7f.sso.duosecurity.com/oauth/<ID>/token
#
# IMPORTANT: scope MUST be "read write" (two scopes, space-separated). Using
# just "write" returns HTTP 401 "Invalid user key in JWT token" even with a
# valid token. The gateway also returns the SAME 401 (instead of the
# documented 403) when your OAuth client has no FMSConsumer access for the
# specific model — request access via the CPP Console before debugging
# headers/payloads.
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=
CISCO_TOKEN_URL=
CISCO_TOKEN_SCOPE=read write
CISCO_EMBEDDING_BASE_URL=https://aiverse.cisco.com/embeddinggemma-300m/v1
CISCO_EMBEDDING_MODEL=google/embeddinggemma-300m
CISCO_RERANK_BASE_URL=https://aiverse.cisco.com/granite-reranker/v1
CISCO_RERANK_MODEL=ibm-granite/granite-embedding-reranker-english-r2
CISCO_REQUEST_TIMEOUT=60
# Set to false if you only have embedding access (skips reranking, returns
# top-k from cosine similarity alone). Lower retrieval quality but useful
# while waiting for granite-reranker provisioning.
CISCO_RERANK_ENABLED=true

# -----------------------------------------------------------------------------
# RAG parameters
# -----------------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVE_TOP_K=20
RERANK_TOP_K=5
